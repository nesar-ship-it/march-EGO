# =============================================================================
# CoachOS — Environment variables
# =============================================================================
# Fill in your real values. Never commit .env or real keys.
# In production, set these in Vercel / EAS / Supabase Edge Function secrets.
# =============================================================================

# --- Client (required for app to run) -----------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL for invite links and redirects (no trailing slash)
# Local: http://localhost:8081  |  Production: https://your-app.vercel.app
EXPO_PUBLIC_APP_URL=http://localhost:8081
EXPO_PUBLIC_APP_NAME=CoachOS

# --- Optional: Razorpay (client key for payment UI) ---------------------------
# EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# =============================================================================
# Server / Edge Functions only — set in Supabase Dashboard → Edge Functions → Secrets
# Do NOT put SUPABASE_SERVICE_ROLE_KEY or other secrets in this file.
# =============================================================================
